# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# handoff source workbooks with personal information
/_handoff/
/_handoff/input/*.xlsx
/_handoff/*.xlsx
/_handoff/**/*.xlsx
/_handoff/output/*.csv

.env*.local

# local smoke-test artifacts and downloaded secrets
.tmp-*
*service-account*.json
*credentials*.json
*oauth*.json
*refresh-token*
